{
  "manifest_version": 3,
  "name": "Foxhole",
  "version": "2.0.0",
  "description": "Habit tracker and screen time monitor. Replaces your new tab.",
  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": ["js/content.js"],
    "run_at": "document_start"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["fonts/0xProto-Regular.ttf"],
    "matches": ["http://*/*", "https://*/*"]
  }]
}
